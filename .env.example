# Example .env file for Playenest project
# Copy this to .env and fill in the values for your local development.

# --- App ---
NODE_ENV="development"
APP_NAME="playenest"
PORT=3000
LOG_LEVEL="info"

# --- Database ---
# Connection string for the PostgreSQL database.
# Default for local Docker setup (see docker-compose.yml):
DATABASE_URL="postgresql://playenest-dev:playenest-dev-password@localhost:5432/playenest-db"
PRISMA_LOG_QUERIES=false

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT / Security ---
# A secure, random string for signing JWTs.
# You can generate one with: openssl rand -hex 32
JWT_ACCESS_SECRET="your-super-secret-access-jwt-key-at-least-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-jwt-key-at-least-32-chars"

# Access token expiration (e.g., 15m, 1h, 1d).
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Optional cookie secret for signed cookies
COOKIE_SECRET="your-cookie-secret-at-least-10-chars"

# --- Webhooks ---
# A secure, random string for verifying incoming payment webhooks.
PAYMENT_PROVIDER_WEBHOOK_SECRET="a-very-secret-key-for-webhook-verification"

# --- ZarinPal ---
ZARINPAL_MERCHANT_ID="00000000-0000-0000-0000-000000000000"
ZARINPAL_CALLBACK_URL="http://localhost:3000/api/v1/payments/callback"
ZARINPAL_SANDBOX=true

# --- CORS ---
# Use "*" to allow all origins or a comma-separated list
CORS_ORIGIN="*"
CORS_CREDENTIALS=true

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE="redis"
RATE_LIMIT_POINTS=10
RATE_LIMIT_DURATION=1
RATE_LIMIT_BLOCK_DURATION=60

# --- Media Storage ---
MEDIA_STORAGE_DRIVER="local" # "local" or "s3"
MEDIA_PUBLIC_BASE_URL="http://localhost:3000"
MEDIA_LOCAL_ROOT="storage"
MEDIA_LOCAL_PUBLIC_PATH="/media"

# S3 Settings (Required if MEDIA_STORAGE_DRIVER="s3")
# MEDIA_S3_BUCKET=""
# MEDIA_S3_REGION=""
# MEDIA_S3_UPLOAD_URL_TEMPLATE=""

# --- Sentry (Optional) ---
SENTRY_ENABLED=false
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=1.0

# --- SMS Service (Smsir.ir) ---
# API key for the SMS service.
SMSIR_API_KEY=""

# The line number provided by the SMS service.
SMSIR_LINE_NUMBER=""

# The template ID for the OTP message.
SMSIR_OTP_TEMPLATE_ID="100000" # Replace with your actual template ID

# Booking template IDs
SMSIR_BOOKING_PENDING_TEMPLATE_ID=""
SMSIR_BOOKING_CONFIRMED_TEMPLATE_ID=""
SMSIR_BOOKING_CANCELED_TEMPLATE_ID=""
